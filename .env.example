# Decap CMS GitHub OAuth - production/Vercel
# GitHub OAuth callback URL:
# https://www.naganamedia.com/api/decap/callback?provider=github
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# DECAP_CMS_SITE_URL="https://www.naganamedia.com"
# DECAP_CMS_GITHUB_SCOPE="repo,user"

# Decap CMS GitHub OAuth - local testing
# To test locally:
# 1. Create a separate GitHub OAuth app with callback:
#    http://localhost:3000/api/decap/callback?provider=github
# 2. Temporarily set public/admin/config.yml backend.base_url to http://localhost:3000
# 3. Comment out the production values above and uncomment these local values.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
DECAP_CMS_SITE_URL="http://localhost:3000"
DECAP_CMS_GITHUB_SCOPE="repo,user"
